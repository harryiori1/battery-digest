{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "battery-digest",
  "compatibility_date": "2026-04-08",
  "main": "src/worker.js",
  "assets": {
    "directory": "output",
    "binding": "ASSETS"
  },
  "kv_namespaces": [
    {
      "binding": "SUBSCRIBERS",
      "id": "5031bf72c84e4c9dbe66c2bd39b7af4b"
    }
  ],
  "triggers": {
    "crons": ["0 9 * * *"]
  }
}
